{
  "name": "fel7o",
  "version": "5.0.1",
  "productName": "Fel7o",
  "description": "Fel7o — Download • Organize • Enjoy",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/extract-ffmpeg.js",
    "start": "node Fel7o.js",
    "dist": "electron-builder"
  },
  "author": "Ahmed Khaled Elfalah",
  "license": "MIT",
  "keywords": [
    "electron",
    "yt-dlp",
    "ffmpeg",
    "downloader",
    "media-player",
    "desktop-app",
    "vanilla-js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedelfalah/fel7o.git"
  },
  "bugs": {
    "url": "https://github.com/ahmedelfalah/fel7o/issues"
  },
  "homepage": "https://github.com/ahmedelfalah/fel7o#readme",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "extract-zip": "^2.0.1"
  },
  "build": {
    "appId": "com.fel7o.app",
    "productName": "Fel7o",
    "directories": { "output": "release" },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "styles.css",
      "*.html",
      "shared/**/*",
      "Fel7o.js",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ]
  }
}
