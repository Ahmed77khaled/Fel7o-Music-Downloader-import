# =============================================
# Fel7o — .gitignore
# =============================================

# Node & Electron dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
release/
build/
out/
coverage/
*.exe
*.msi
# Exclude zip archives globally (binaries stay local, not versioned)
*.zip

# Binary overrides
# ffmpeg.zip is kept (postinstall extracts it to ffmpeg.exe)
# ffmpeg.exe is excluded — too large for GitHub (127 MB > 100 MB limit)
bin/ffmpeg.exe

# Logs
*.log
*.tmp
*.cache

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Environment and IDE settings
.env
.env.local
.vscode/
.idea/
*.suo
*.user
